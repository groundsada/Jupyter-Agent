{
  "name": "@groundsada/jupyterhub-vscode",
  "version": "0.1.0",
  "description": "JupyterLab extension: Open in VS Code via SSH",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "vscode",
    "ssh"
  ],
  "homepage": "https://github.com/groundsada/jupyter-ssh",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*.{d.ts,js,js.map}",
    "style/**/*.css",
    "schema/**/*.json"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run clean && npm run build:lib:prod && npm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "npm run clean:lib && npm run clean:labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyterhub_vscode/labextension",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "~5.0.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jhub_vscode_labext/labextension"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  }
}
