{
  "name": "jhub-vscode",
  "displayName": "JupyterHub Remote",
  "description": "One-click VS Code connection to JupyterHub server pods via SSH",
  "version": "0.1.0",
  "publisher": "groundsada",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/groundsada/jupyter-ssh"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "jupyterhub",
    "remote",
    "ssh",
    "jupyter"
  ],
  "activationEvents": [
    "onUri"
  ],
  "extensionDependencies": [
    "ms-vscode-remote.remote-ssh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jhub-vscode.reconnect",
        "title": "JupyterHub: Reconnect to server"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "build": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^2.22.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "~5.3.0"
  },
  "binaryVersion": "0.1.0",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
